    "@elysiajs/cors": "^1.2.0",
    "drizzle-orm": "^0.38.0",
    "mysql2": "^3.11.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "bun-types": "^1.3.0"
  }
}
